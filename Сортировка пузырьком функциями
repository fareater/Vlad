#include <stdio.h>
#include <stdlib.h>
#include <time.h>
int max(int a,int b) {return (a>b);}
int min(int a,int b) {return (a<b);}
void sort(int *arry,int m,int (*operator)(int,int)) {
    for (int i=0;i<m;i++) {
        for (int j=0;j< m - 1 - i;j++) {
            if (operator(arry[j],arry[j + 1])) {
                int temp = arry[j];
                arry[j] = arry[j + 1];
                arry[j + 1] = temp;
            }

        }
    }
}
int main(){
    int n = 20;
    int arry[n];
    srand(time(NULL));
    for(int i=0;i<n;i++) {
        arry[i]=rand()%100;
    }
    printf("Сортировка от минимума к максимумум:");
    sort(arry,n,max);
    for(int i=0;i<n;i++) {
        printf("%d ",arry[i]);
    }
    printf("\n");
    printf("Сортировка от максимума к минимума:");
    sort(arry,n,min);
    for(int i=0;i<n;i++) {
        printf("%d ",arry[i]);
    }
    return 0;
}
